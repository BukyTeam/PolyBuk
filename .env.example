# ============================================================
# PolyBuk Framework - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to git. It contains secrets.
# ============================================================

# --- Polymarket Authentication ---
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_PRIVATE_KEY=
# The Gnosis Safe proxy address that holds your USDC on Polymarket.
# Accounts created via the Polymarket web UI are Safe-based by default.
# Find it in Polymarket UI → profile → Deposit. Leave empty only if
# your account trades directly from the EOA (rare).
POLYMARKET_FUNDER_ADDRESS=

# --- Supabase (Database) ---
SUPABASE_URL=https://lmceipqpnbuomuwuxkym.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# --- Telegram Alerts ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Logging ---
LOG_LEVEL=INFO
